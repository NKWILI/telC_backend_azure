# Database — Neon pooled connection (used by Prisma at runtime)
DATABASE_URL=postgresql://neondb_owner:[PASSWORD]@ep-xxx-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Database — Neon direct connection (used by prisma migrate — non-pooler URL)
DIRECT_DATABASE_URL=postgresql://neondb_owner:[PASSWORD]@ep-xxx.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Google Generative AI
GEMINI_API_KEY=your_gemini_api_key_here

# Email Service
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com   # must be a verified sender in your Resend account

# Authentication — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Token hashing — HMAC key for verification and reset tokens
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
TOKEN_HMAC_SECRET=

# Google OAuth — Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# Frontend URL — used in password-reset email links and as the
# verification-link fallback when VITRINE_URL is unset.
FRONTEND_URL=https://your-flutter-web-url.com

# Vitrine (marketing site) URL — target for verification email links so a
# user clicking from any device lands on the public success/fail page.
# If unset, verification links fall back to FRONTEND_URL.
VITRINE_URL=https://sprach-tau.vercel.app

# Server Configuration
PORT=3000

# Rate limits — overrides for the in-memory rate limiter (optional, defaults shown)
# RATE_LIMIT_FORGOT_PASSWORD_MAX_ATTEMPTS=5
# RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MINUTES=15
# RATE_LIMIT_RESET_PASSWORD_MAX_ATTEMPTS=20
# RATE_LIMIT_RESET_PASSWORD_WINDOW_MINUTES=15
# RATE_LIMIT_VERIFY_EMAIL_PUBLIC_MAX_ATTEMPTS=10
# RATE_LIMIT_VERIFY_EMAIL_PUBLIC_WINDOW_MINUTES=15

# CORS — comma-separated list of allowed frontend origins.
# Must include the vitrine origin so its /verify-email page can POST to
# /api/auth/verify-email-public. Add Vercel preview origins as needed.
# Example: ALLOWED_ORIGINS=https://app.example.com,https://sprach-tau.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://sprach-tau.vercel.app
